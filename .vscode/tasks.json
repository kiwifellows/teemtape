{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "api: wrangler dev",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/workers/api"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "wrangler",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Ready on http://(localhost|127\\.0\\.0\\.1):8787"
        }
      }
    }
  ]
}
