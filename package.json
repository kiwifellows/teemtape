{
  "name": "teemtape",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source ticker app for commenting on stocks (CLI, web, mobile).",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "workers/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @teemtape/api-client && npm run build --workspace @teemtape/cli",
    "test": "npm run test --workspaces --if-present",
    "mock": "node packages/mock-server/src/index.mjs",
    "cli": "node packages/cli/dist/index.js",
    "api:dev": "npm run dev --workspace @teemtape/api"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "ws": "8.21.0"
  }
}
