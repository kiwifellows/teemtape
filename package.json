{
  "name": "teemtape",
  "version": "0.1.4",
  "private": true,
  "description": "Open-source ticker app for commenting on stocks (CLI, web, mobile).",
  "license": "MIT",
  "author": "Benjamin Fellows",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "workers/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @teemtape/api-client && npm run build --workspace @teemtape/cli && npm run build --workspace @teemtape/web",
    "test": "npm run test --workspaces --if-present",
    "mock": "node packages/mock-server/src/index.mjs",
    "cli": "node packages/cli/dist/index.js",
    "api:dev": "npm run dev --workspace @teemtape/api",
    "web:dev": "npm run dev --workspace @teemtape/web",
    "web:build": "npm run build --workspace @teemtape/web",
    "web:pages:dev": "npm run pages:dev --workspace @teemtape/web",
    "web:deploy": "npm run deploy --workspace @teemtape/web"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "ws": "8.21.0",
    "undici": "7.28.0",
    "vite": {
      "esbuild": "0.25.12"
    }
  }
}
