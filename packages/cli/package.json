    "dev": "tsup --watch",
    "test": "node --test",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@teemtape/api-client": "^0.1.4",
    "commander": "^12.1.0",
    "undici": "^7.28.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
